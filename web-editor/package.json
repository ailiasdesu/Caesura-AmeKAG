{
    "name":  "caesura-amekag",
    "private":  true,
    "version":  "0.1.0-alpha",
    "type":  "module",
    "scripts":  {
                    "dev":  "concurrently -n vite,electron \"vite\" \"wait-on http://localhost:5173 \u0026\u0026 electron . --dev\"",
                    "build":  "vite build",
                    "preview":  "vite preview",
                    "package":  "vite build \u0026\u0026 electron-builder --win --mac --linux",
                    "package:win":  "vite build \u0026\u0026 electron-builder --win",
                    "package:mac":  "vite build \u0026\u0026 electron-builder --mac",
                    "package:linux":  "vite build \u0026\u0026 electron-builder --linux"
                },
    "dependencies":  {
                         "@codemirror/autocomplete":  "^6.20.3",
                         "@codemirror/commands":  "^6.10.3",
                         "@codemirror/fold":  "^0.19.4",
                         "@codemirror/language":  "^6.12.3",
                         "@codemirror/legacy-modes":  "^6.5.3",
                         "@codemirror/lint":  "^6.9.7",
                         "@codemirror/search":  "^6.7.0",
                         "@codemirror/state":  "^6.6.0",
                         "@codemirror/theme-one-dark":  "^6.1.3",
                         "@codemirror/view":  "^6.43.1",
                         "@lezer/highlight":  "^1.2.3",
                         "react":  "^18.3.1",
                         "react-dom":  "^18.3.1"
                     },
    "devDependencies":  {
                            "@types/react":  "^18.3.3",
                            "@types/react-dom":  "^18.3.0",
                            "@vitejs/plugin-react":  "^4.3.1",
                            "concurrently":  "^10.0.3",
                            "electron":  "^42.3.3",
                            "electron-builder":  "^26.15.0",
                            "vite":  "^5.3.1",
                            "wait-on":  "^9.0.10"
                        },
    "main":  "electron/main.cjs",
    "build":  {
                  "appId":  "com.caesura.amekag",
                  "productName":  "Caesura (AmeKAG)",
                  "directories":  {
                                      "output":  "release"
                                  },
                  "files":  [
                                "dist/**/*",
                                "electron/**/*",
                                "package.json"
                            ],
                  "extraResources":  [
                                         {
                                             "from":  "../build_nol2d/Release",
                                             "to":  "engine",
                                             "filter":  [
                                                            "CaesuraAmeKAG.exe",
                                                            "*.exe",
                                                            "*.dll",
                                                            "scripts/**",
                                                            "assets/**",
                                                            "demo/**"
                                                        ]
                                         }
                                     ],
                  "win":  {
                              "target":  [
                                             "nsis"
                                         ],
                              "icon":  "assets/icon.ico"
                          },
                  "mac":  {
                              "target":  [
                                             "dmg"
                                         ],
                              "icon":  "assets/icon.icns",
                              "category":  "public.app-category.developer-tools"
                          },
                  "linux":  {
                                "target":  [
                                               "AppImage"
                                           ],
                                "icon":  "assets/icon.png",
                                "category":  "Development"
                            },
                  "nsis":  {
                               "oneClick":  false,
                               "allowToChangeInstallationDirectory":  true,
                               "installerIcon":  "assets/icon.ico"
                           }
              }
}
